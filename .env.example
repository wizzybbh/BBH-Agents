# Copy to .env (gitignored) and fill in. Scripts and skills read these.

# --- VPS (where recon lives; where the agent runs) ---
# Prefer an SSH host alias in ~/.ssh/config, e.g. `Host recon-vps`.
VPS_HOST=recon-vps
VPS_TARGETS_DIR=~/targets            # per-program working dir on the VPS

# --- HackerOne / BugCrowd identity (from your program's policy) ---
H1_HANDLE=your-h1-username
# Required User-Agent many programs mandate (often your handle). Skills echo it.
TESTING_USER_AGENT=your-h1-username
# Registration email alias, e.g. your-h1-username@wearehackerone.com
REG_EMAIL=

# --- Recon pipeline (scripts/recon-pipeline.sh) ---
GITHUB_TOKEN=                          # raises GitHub search/rate limits (github-subdomains, dorking)
RECON_RATE=50                          # req/s cap for httpx/katana (be polite; lower for sensitive programs)
RECON_WORDLIST=                        # DNS brute wordlist for --active (e.g. ~/wordlists/dns/best-dns.txt)
RECON_RESOLVERS=                       # trusted resolvers file for --active (e.g. ~/wordlists/resolvers.txt)

# --- Caido (read + suggest only; the AI never sends traffic) ---
# Caido exposes a plugin/GraphQL API on its local instance.
CAIDO_API_URL=http://127.0.0.1:8080/graphql
CAIDO_API_TOKEN=
